# Public contact & social URLs (used in `src/data/homeContent.js` footer).
# Copy to `.env`, replace with your real values. Vite only exposes variables prefixed with `VITE_`.

VITE_PRODUCER_BRAND=Example Producer
VITE_CONTACT_EMAIL=contact@example.com
VITE_SOCIAL_YOUTUBE=https://www.youtube.com/@example
VITE_SOCIAL_SPOTIFY="https://open.spotify.com/artist/0000000000000000000000?example=1"
VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/example
