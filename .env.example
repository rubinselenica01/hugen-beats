# Copy to `.env`. Vite only exposes variables prefixed with `VITE_`.

# ── Backend API (FastAPI) ───────────────────────────────────────────────────────
# Base URL **without** a trailing slash. Used by `src/utils/apiBase.js` for auth and other calls.
#
# Leave empty for local dev with the default Vite dev server proxy (`vite.config.js` forwards `/admin/*`,
# `/catalog/*`, and JSON `/beats` API routes to the backend so cookies stay same-origin for admin calls).
# Public catalog data uses GET `/catalog/beats` (no auth). Admin beat list stays GET `/beats` (requires login).
#
# When set, the hostname must match how you open the app: use `localhost` in the URL if you use
# http://localhost:5173 — not 127.0.0.1 (browsers treat localhost vs 127.0.0.1 as different sites
# and may not send SameSite session cookies across that mismatch).
#
# Set when your UI hits the API directly (no Vite proxy), e.g.:
#   VITE_API_URL=http://localhost:8000
#   VITE_API_URL=https://api.example.com
VITE_API_URL=

# ── Brand & marketing (footer, etc.) ──────────────────────────────────────────
VITE_PRODUCER_BRAND=Example Producer
VITE_CONTACT_EMAIL=contact@example.com
VITE_SOCIAL_YOUTUBE=https://www.youtube.com/@example
VITE_SOCIAL_SPOTIFY="https://open.spotify.com/artist/0000000000000000000000?example=1"
VITE_SOCIAL_INSTAGRAM=https://www.instagram.com/example
